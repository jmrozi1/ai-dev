now_utc_iso_timestamp() {
	python3 - <<'PY'
from datetime import datetime, timezone

print(datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z'))
PY
}

format_blocked_workflow_summary_lines() {
	local blocked_json="$1"

	python3 - "$blocked_json" <<'PY'
import json
import sys

try:
	data = json.loads(sys.argv[1])
except json.JSONDecodeError:
	print('')
	sys.exit(0)

items = data.get('blockedWorkflows', [])
if not isinstance(items, list) or not items:
	print('  none')
	sys.exit(0)

normalized = []
for item in items:
	if not isinstance(item, dict):
		continue
	issue_number = item.get('issueNumber')
	issue_title = item.get('issueTitle')
	reason = item.get('reason')
	if not isinstance(issue_number, int):
		continue
	if not isinstance(issue_title, str):
		issue_title = ''
	if not isinstance(reason, str):
		reason = ''
	normalized.append((issue_number, issue_title.strip(), reason.strip()))

if not normalized:
	print('  none')
	sys.exit(0)

for issue_number, issue_title, reason in sorted(normalized, key=lambda x: x[0]):
	if issue_title:
		print(f'  issue {issue_number} - {issue_title}')
	else:
		print(f'  issue {issue_number}')
	print(f'    reason: {reason}')
PY
}

git_status_value() {
	local value="$1"
	if [[ "$value" == 'yes' ]]; then
		printf 'yes'
		return 0
	fi
	printf 'no'
}

classify_porcelain_entry() {
	local entry="$1"
	local x_status="${entry:0:1}"
	local y_status="${entry:1:1}"

	local staged='no'
	local unstaged='no'
	local untracked='no'

	if [[ "$x_status$y_status" == '??' ]]; then
		untracked='yes'
	else
		if [[ "$x_status" != ' ' ]]; then
			staged='yes'
		fi

		if [[ "$y_status" != ' ' ]]; then
			unstaged='yes'
		fi
	fi

	printf '%s %s %s\n' "$staged" "$unstaged" "$untracked"
}

summarize_porcelain_status() {
	local porcelain_status="$1"

	local staged='no'
	local unstaged='no'
	local untracked='no'
	local line
	while IFS= read -r line; do
		if [[ -z "$line" ]]; then
			continue
		fi

		local entry_staged entry_unstaged entry_untracked
		read -r entry_staged entry_unstaged entry_untracked <<< "$(classify_porcelain_entry "$line")"

		if [[ "$entry_staged" == 'yes' ]]; then
			staged='yes'
		fi

		if [[ "$entry_unstaged" == 'yes' ]]; then
			unstaged='yes'
		fi

		if [[ "$entry_untracked" == 'yes' ]]; then
			untracked='yes'
		fi
	done <<< "$porcelain_status"

	local working_tree='clean'
	if [[ "$staged" == 'yes' || "$unstaged" == 'yes' || "$untracked" == 'yes' ]]; then
		working_tree='dirty'
	fi

	printf '%s %s %s %s\n' "$staged" "$unstaged" "$untracked" "$working_tree"
}

branch_state_for_repo() {
	local repo_root="$1"
	local main_branch="$2"
	local scratch_branch="$3"

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		printf 'main branch missing'
		return 0
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		printf 'scratch branch missing'
		return 0
	fi

	local counts
	counts="$(git -C "$repo_root" rev-list --left-right --count "${main_branch}...${scratch_branch}")"

	local main_only_count scratch_only_count
	IFS=$' \t' read -r main_only_count scratch_only_count <<< "$counts"

	if [[ "$main_only_count" -eq 0 && "$scratch_only_count" -eq 0 ]]; then
		printf 'scratch equal to main'
		return 0
	fi

	if [[ "$main_only_count" -eq 0 ]]; then
		printf 'scratch ahead of main by %s commit(s)' "$scratch_only_count"
		return 0
	fi

	if [[ "$scratch_only_count" -eq 0 ]]; then
		printf 'scratch behind main by %s commit(s)' "$main_only_count"
		return 0
	fi

	printf 'scratch and main have diverged: scratch ahead by %s commit(s), behind by %s commit(s)' "$scratch_only_count" "$main_only_count"
}

branch_relation_info_for_repo() {
	local repo_root="$1"
	local main_branch="$2"
	local scratch_branch="$3"

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		printf 'missing-main 0 0\n'
		return 0
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		printf 'missing-scratch 0 0\n'
		return 0
	fi

	local counts
	counts="$(git -C "$repo_root" rev-list --left-right --count "${main_branch}...${scratch_branch}")"

	local main_only_count scratch_only_count
	IFS=$' \t' read -r main_only_count scratch_only_count <<< "$counts"

	if [[ "$main_only_count" -eq 0 && "$scratch_only_count" -eq 0 ]]; then
		printf 'equal 0 0\n'
		return 0
	fi

	if [[ "$main_only_count" -eq 0 ]]; then
		printf 'ahead %s %s\n' "$main_only_count" "$scratch_only_count"
		return 0
	fi

	if [[ "$scratch_only_count" -eq 0 ]]; then
		printf 'behind %s %s\n' "$main_only_count" "$scratch_only_count"
		return 0
	fi

	printf 'diverged %s %s\n' "$main_only_count" "$scratch_only_count"
}

relationship_line_for_default_status() {
	local relation_state="$1"
	local main_branch="$2"
	local scratch_branch="$3"
	local main_only_count="$4"
	local scratch_only_count="$5"

	case "$relation_state" in
		ahead)
			if [[ "$scratch_only_count" -eq 1 ]]; then
				printf '1 commit ahead of %s' "$main_branch"
			else
				printf '%s commits ahead of %s' "$scratch_only_count" "$main_branch"
			fi
			return 0
			;;
		behind)
			if [[ "$main_only_count" -eq 1 ]]; then
				printf '1 commit behind %s' "$main_branch"
			else
				printf '%s commits behind %s' "$main_only_count" "$main_branch"
			fi
			return 0
			;;
		diverged)
			printf 'Branches have diverged: %s on %s, %s on %s' "$main_only_count" "$main_branch" "$scratch_only_count" "$scratch_branch"
			return 0
			;;
		*)
			return 0
			;;
	esac
}

relationship_line_for_verbose_status() {
	local relation_state="$1"
	local main_only_count="$2"
	local scratch_only_count="$3"
	local main_branch="$4"
	local scratch_branch="$5"

	case "$relation_state" in
		equal)
			printf '%s equals %s' "$scratch_branch" "$main_branch"
			;;
		ahead)
			if [[ "$scratch_only_count" -eq 1 ]]; then
				printf '%s is 1 commit ahead of %s' "$scratch_branch" "$main_branch"
			else
				printf '%s is %s commits ahead of %s' "$scratch_branch" "$scratch_only_count" "$main_branch"
			fi
			;;
		behind)
			if [[ "$main_only_count" -eq 1 ]]; then
				printf '%s is 1 commit behind %s' "$scratch_branch" "$main_branch"
			else
				printf '%s is %s commits behind %s' "$scratch_branch" "$main_only_count" "$main_branch"
			fi
			;;
		diverged)
			printf '%s and %s have diverged: %s on %s, %s on %s' "$scratch_branch" "$main_branch" "$main_only_count" "$main_branch" "$scratch_only_count" "$scratch_branch"
			;;
		missing-main)
			printf '%s branch missing' "$main_branch"
			;;
		missing-scratch)
			printf '%s branch missing' "$scratch_branch"
			;;
		*)
			printf 'relationship unavailable'
			;;
	esac
}

normalize_status_path_list() {
	local paths="$1"

	if [[ -z "$paths" ]]; then
		return 0
	fi

	printf '%s\n' "$paths" | awk 'length($0) > 0' | LC_ALL=C sort -u
}

count_status_paths() {
	local paths="$1"

	if [[ -z "$paths" ]]; then
		printf '0'
		return 0
	fi

	awk 'length($0) > 0 { count += 1 } END { print count + 0 }' <<< "$paths"
}

collect_status_details() {
	local porcelain_status="$1"

	local staged_paths=''
	local modified_paths=''
	local untracked_paths=''
	local line
	while IFS= read -r line; do
		if [[ -z "$line" ]]; then
			continue
		fi

		local x_status="${line:0:1}"
		local y_status="${line:1:1}"
		local path_text="${line:3}"

		if [[ "$x_status$y_status" == '??' ]]; then
			untracked_paths+="${path_text}"$'\n'
			continue
		fi

		if [[ "$x_status" != ' ' ]]; then
			staged_paths+="${path_text}"$'\n'
		fi

		if [[ "$y_status" != ' ' ]]; then
			modified_paths+="${path_text}"$'\n'
		fi
	done <<< "$porcelain_status"

	STATUS_STAGED_PATHS="$(normalize_status_path_list "$staged_paths")"
	STATUS_MODIFIED_PATHS="$(normalize_status_path_list "$modified_paths")"
	STATUS_UNTRACKED_PATHS="$(normalize_status_path_list "$untracked_paths")"

	STATUS_STAGED_COUNT="$(count_status_paths "$STATUS_STAGED_PATHS")"
	STATUS_MODIFIED_COUNT="$(count_status_paths "$STATUS_MODIFIED_PATHS")"
	STATUS_UNTRACKED_COUNT="$(count_status_paths "$STATUS_UNTRACKED_PATHS")"

	STATUS_WORKING_TREE='clean'
	if [[ "$STATUS_STAGED_COUNT" -gt 0 || "$STATUS_MODIFIED_COUNT" -gt 0 || "$STATUS_UNTRACKED_COUNT" -gt 0 ]]; then
		STATUS_WORKING_TREE='dirty'
	fi
}

print_status_path_category() {
	local category_name="$1"
	local paths="$2"

	if [[ -z "$paths" ]]; then
		return 0
	fi

	printf '  %s:\n' "$category_name"
	while IFS= read -r line; do
		if [[ -z "$line" ]]; then
			continue
		fi
		printf '    %s\n' "$line"
	done <<< "$paths"
}

print_status_count_line() {
	local count="$1"
	local label="$2"

	if [[ "$count" -eq 1 ]]; then
		printf '  1 %s\n' "$label"
		return 0
	fi

	printf '  %s %s\n' "$count" "$label"
}

normalize_branch_name_for_status() {
	local raw_branch="$1"

	if [[ "$raw_branch" == 'HEAD' ]]; then
		printf 'detached HEAD'
		return 0
	fi

	printf '%s' "$raw_branch"
}

handle_status() {
	local argument_count="$1"
	shift

	local verbose='no'
	if [[ "$argument_count" -eq 0 ]]; then
		:
	elif [[ "$argument_count" -eq 1 ]]; then
		local first_argument="${1:-}"
		if [[ "$first_argument" == '-v' || "$first_argument" == '--verbose' ]]; then
			verbose='yes'
		else
			error "Usage: ${script_name} status [-v|--verbose]"
		fi
	else
		error "Usage: ${script_name} status [-v|--verbose]"
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"

	local workflow_state_file
	workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
	local state_json
	state_json="$(workflow_state_json_helper 'get' "$workflow_state_file")"

	local active_issue_number
	active_issue_number="$(workflow_state_get_field 'activeIssueNumber' "$state_json")"
	local active_issue_title
	active_issue_title="$(workflow_state_get_field 'activeIssueTitle' "$state_json")"
	local active_issue_url
	active_issue_url="$(workflow_state_get_field 'activeIssueUrl' "$state_json")"
	local patch_description
	patch_description="$(workflow_state_get_field 'patchDescription' "$state_json")"
	local main_branch
	main_branch="$(workflow_state_get_field 'mainBranch' "$state_json")"
	local scratch_branch
	scratch_branch="$(workflow_state_get_field 'scratchBranch' "$state_json")"
	local checkpoint
	checkpoint="$(workflow_state_get_field 'checkpoint' "$state_json")"

	local workflow_kind
	workflow_kind="$(workflow_kind_from_state "$active_issue_number" "$patch_description")"
	local workflow_status='inactive'
	if [[ "$workflow_kind" != 'inactive' ]]; then
		workflow_status='active'
	fi

	local porcelain_status
	porcelain_status="$(git -C "$repo_root" status --porcelain --untracked-files=all)"
	collect_status_details "$porcelain_status"

	local current_branch
	current_branch="$(normalize_branch_name_for_status "$(git -C "$repo_root" rev-parse --abbrev-ref HEAD)")"

	local relation_state main_only_count scratch_only_count
	read -r relation_state main_only_count scratch_only_count <<< "$(branch_relation_info_for_repo "$repo_root" "$main_branch" "$scratch_branch")"

	local blocked_workflows_file
	blocked_workflows_file="$(blocked_workflows_file_for_repo_root "$repo_root")"
	local blocked_workflows_json
	blocked_workflows_json="$(blocked_workflows_json_helper 'get' "$blocked_workflows_file")"

	if [[ "$verbose" == 'yes' ]]; then
		printf 'Workflow:\n'
		if [[ "$workflow_status" == 'active' ]]; then
			printf '  state: active\n'
			printf '  type: %s\n' "$workflow_kind"
			if [[ "$workflow_kind" == 'issue' ]]; then
				printf '  issue number: %s\n' "$active_issue_number"
				if [[ -n "$active_issue_title" ]]; then
					printf '  issue title: %s\n' "$active_issue_title"
				fi
				if [[ -n "$active_issue_url" ]]; then
					printf '  issue URL: %s\n' "$active_issue_url"
				fi
			elif [[ "$workflow_kind" == 'patch' ]]; then
				printf '  patch: %s\n' "$patch_description"
			fi
			printf '  checkpoint: %s\n' "$checkpoint"
		else
			printf '  state: inactive\n'
			printf '  checkpoint: %s\n' "$checkpoint"
		fi

		printf 'Repository:\n'
		printf '  current branch: %s\n' "$current_branch"
		printf '  main branch: %s\n' "$main_branch"
		printf '  scratch branch: %s\n' "$scratch_branch"
		printf '  relation: %s\n' "$(relationship_line_for_verbose_status "$relation_state" "$main_only_count" "$scratch_only_count" "$main_branch" "$scratch_branch")"

		printf 'Working tree:\n'
		if [[ "$STATUS_WORKING_TREE" == 'clean' ]]; then
			printf '  clean\n'
		else
			print_status_path_category 'staged' "$STATUS_STAGED_PATHS"
			print_status_path_category 'modified' "$STATUS_MODIFIED_PATHS"
			print_status_path_category 'untracked' "$STATUS_UNTRACKED_PATHS"
		fi

		printf 'Blocked workflows:\n'
		format_blocked_workflow_summary_lines "$blocked_workflows_json"
		return 0
	fi

	if [[ "$workflow_status" == 'active' ]]; then
		if [[ "$workflow_kind" == 'issue' ]]; then
			if [[ -n "$active_issue_title" ]]; then
				printf 'Issue %s — %s\n' "$active_issue_number" "$active_issue_title"
			else
				printf 'Issue %s\n' "$active_issue_number"
			fi
		elif [[ "$workflow_kind" == 'patch' ]]; then
			printf 'Patch: %s\n' "$patch_description"
		fi
	else
		printf 'No active workflow.\n'
	fi
	printf 'Branch: %s\n' "$current_branch"

	local relationship_line=''
	relationship_line="$(relationship_line_for_default_status "$relation_state" "$main_branch" "$scratch_branch" "$main_only_count" "$scratch_only_count")"

	local has_deviation='no'
	if [[ "$workflow_status" == 'active' && "$current_branch" != "$scratch_branch" ]]; then
		has_deviation='yes'
	fi
	if [[ -n "$relationship_line" ]]; then
		has_deviation='yes'
	fi
	if [[ "$STATUS_STAGED_COUNT" -gt 0 || "$STATUS_MODIFIED_COUNT" -gt 0 || "$STATUS_UNTRACKED_COUNT" -gt 0 ]]; then
		has_deviation='yes'
	fi

	local checkpoint_conveyed='no'
	if [[ "$relation_state" == 'ahead' && "$scratch_only_count" -eq "$checkpoint" ]]; then
		checkpoint_conveyed='yes'
	fi

	if [[ "$checkpoint" != '0' && "$checkpoint_conveyed" != 'yes' ]]; then
		has_deviation='yes'
	fi

	if [[ "$has_deviation" != 'yes' ]]; then
		return 0
	fi

	printf '\nWorking tree:\n'

	if [[ "$workflow_status" == 'active' && "$current_branch" != "$scratch_branch" ]]; then
		printf '  Expected branch: %s\n' "$scratch_branch"
	fi

	if [[ -n "$relationship_line" ]]; then
		printf '  %s\n' "$relationship_line"
	fi

	if [[ "$STATUS_STAGED_COUNT" -gt 0 ]]; then
		print_status_count_line "$STATUS_STAGED_COUNT" 'staged'
	fi

	if [[ "$STATUS_MODIFIED_COUNT" -gt 0 ]]; then
		print_status_count_line "$STATUS_MODIFIED_COUNT" 'modified'
	fi

	if [[ "$STATUS_UNTRACKED_COUNT" -gt 0 ]]; then
		print_status_count_line "$STATUS_UNTRACKED_COUNT" 'untracked'
	fi

	if [[ "$checkpoint" != '0' && "$checkpoint_conveyed" != 'yes' ]]; then
		printf '  Checkpoint: %s\n' "$checkpoint"
	fi
}

handle_review() {
	local argument_count="$1"
	shift

	if [[ "$argument_count" -ne 0 ]]; then
		error "Usage: ${script_name} review"
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"

	local workflow_state_file
	workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
	local state_json
	state_json="$(workflow_state_json_helper 'get' "$workflow_state_file")"

	local active_issue_number
	active_issue_number="$(workflow_state_get_field 'activeIssueNumber' "$state_json")"
	local patch_description
	patch_description="$(workflow_state_get_field 'patchDescription' "$state_json")"
	local workflow_kind
	workflow_kind="$(workflow_kind_from_state "$active_issue_number" "$patch_description")"
	if [[ "$workflow_kind" == 'inactive' ]]; then
		error 'Cannot review workflow: no active issue is set.'
	fi

	local main_branch
	main_branch="$(workflow_state_get_field 'mainBranch' "$state_json")"
	local scratch_branch
	scratch_branch="$(workflow_state_get_field 'scratchBranch' "$state_json")"

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		error "Main branch does not exist locally: ${main_branch}"
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		error "Scratch branch does not exist locally: ${scratch_branch}"
	fi

	local current_branch
	current_branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD)"
	if [[ "$current_branch" != "$scratch_branch" ]]; then
		error "Cannot review workflow: current branch ${current_branch} does not match scratchBranch ${scratch_branch}."
	fi

	local porcelain_status
	porcelain_status="$(git -C "$repo_root" status --porcelain --untracked-files=all)"
	local staged unstaged untracked working_tree
	read -r staged unstaged untracked working_tree <<< "$(summarize_porcelain_status "$porcelain_status")"
	if [[ "$working_tree" == 'clean' ]]; then
		error 'No proposed changes to review.'
	fi

	git -C "$repo_root" add --all

	local diff_status=0
	set +e
	git -C "$repo_root" diff --cached --binary --no-ext-diff --quiet
	diff_status=$?
	set -e
	if [[ "$diff_status" -eq 0 ]]; then
		error 'No staged changes available for review.'
	fi
	if [[ "$diff_status" -ne 1 ]]; then
		return "$diff_status"
	fi

	if [[ "$workflow_kind" == 'patch' ]]; then
		printf 'Patch: %s\n\n' "$patch_description"
	fi

	git -C "$repo_root" diff --cached --binary --no-ext-diff
}

handle_commit() {
	local argument_count="$1"
	shift

	if [[ "$argument_count" -ne 0 ]]; then
		error "Usage: ${script_name} commit"
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"

	local workflow_state_file
	workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
	local state_json
	state_json="$(workflow_state_json_helper 'get' "$workflow_state_file")"

	local active_issue_number
	active_issue_number="$(workflow_state_get_field 'activeIssueNumber' "$state_json")"
	local patch_description
	patch_description="$(workflow_state_get_field 'patchDescription' "$state_json")"
	local workflow_kind
	workflow_kind="$(workflow_kind_from_state "$active_issue_number" "$patch_description")"
	if [[ "$workflow_kind" == 'inactive' ]]; then
		error 'Cannot commit workflow: no active issue is set.'
	fi

	local active_issue_title
	active_issue_title="$(workflow_state_get_field 'activeIssueTitle' "$state_json")"
	local active_issue_url
	active_issue_url="$(workflow_state_get_field 'activeIssueUrl' "$state_json")"
	local main_branch
	main_branch="$(workflow_state_get_field 'mainBranch' "$state_json")"
	local scratch_branch
	scratch_branch="$(workflow_state_get_field 'scratchBranch' "$state_json")"
	local checkpoint
	checkpoint="$(workflow_state_get_field 'checkpoint' "$state_json")"

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		error "Main branch does not exist locally: ${main_branch}"
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		error "Scratch branch does not exist locally: ${scratch_branch}"
	fi

	local current_branch
	current_branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD)"
	if [[ "$current_branch" != "$scratch_branch" ]]; then
		error "Cannot commit workflow: current branch ${current_branch} does not match scratchBranch ${scratch_branch}."
	fi

	local porcelain_status
	porcelain_status="$(git -C "$repo_root" status --porcelain --untracked-files=all)"
	local staged unstaged untracked working_tree
	read -r staged unstaged untracked working_tree <<< "$(summarize_porcelain_status "$porcelain_status")"

	if [[ "$unstaged" == 'yes' ]]; then
		error 'Cannot commit workflow: unstaged tracked changes are present.'
	fi

	if [[ "$untracked" == 'yes' ]]; then
		error 'Cannot commit workflow: untracked files are present.'
	fi

	if [[ "$staged" != 'yes' ]]; then
		error 'Cannot commit workflow: no staged changes are available.'
	fi

	local new_checkpoint=$(( checkpoint + 1 ))
	if ! git -C "$repo_root" commit -q --message "$new_checkpoint"; then
		error 'Git commit failed.'
	fi

	local state_payload
	if [[ "$workflow_kind" == 'patch' ]]; then
		state_payload="$(build_patch_state_payload "$patch_description" "$main_branch" "$scratch_branch" "$new_checkpoint")"
	else
		state_payload="$(build_issue_checkpoint_state_payload "$active_issue_number" "$active_issue_title" "$active_issue_url" "$main_branch" "$scratch_branch" "$new_checkpoint")"
	fi
	workflow_state_json_helper 'set' "$workflow_state_file" "$state_payload" >/dev/null

	local commit_hash
	commit_hash="$(git -C "$repo_root" rev-parse HEAD)"
	printf 'Created checkpoint %s\n' "$new_checkpoint"
	printf 'commit: %s\n' "$commit_hash"
	if [[ "$workflow_kind" == 'patch' ]]; then
		printf 'patch: %s\n' "$patch_description"
	else
		printf 'activeIssueNumber: %s\n' "$active_issue_number"
	fi
}

handle_reset() {
	local argument_count="$1"
	shift

	if [[ "$argument_count" -ne 0 ]]; then
		error "Usage: ${script_name} reset"
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"

	local workflow_state_file
	workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
	local state_json
	state_json="$(workflow_state_json_helper 'get' "$workflow_state_file")"

	local active_issue_number
	active_issue_number="$(workflow_state_get_field 'activeIssueNumber' "$state_json")"
	local patch_description
	patch_description="$(workflow_state_get_field 'patchDescription' "$state_json")"
	local workflow_kind
	workflow_kind="$(workflow_kind_from_state "$active_issue_number" "$patch_description")"
	if [[ "$workflow_kind" == 'inactive' ]]; then
		error 'Cannot reset workflow: no active issue is set.'
	fi

	local active_issue_title
	active_issue_title="$(workflow_state_get_field 'activeIssueTitle' "$state_json")"
	local active_issue_url
	active_issue_url="$(workflow_state_get_field 'activeIssueUrl' "$state_json")"
	local main_branch
	main_branch="$(workflow_state_get_field 'mainBranch' "$state_json")"
	local scratch_branch
	scratch_branch="$(workflow_state_get_field 'scratchBranch' "$state_json")"

	if [[ "$main_branch" == "$scratch_branch" ]]; then
		error 'Invalid workflow state: mainBranch and scratchBranch must be different.'
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		error "Main branch does not exist locally: ${main_branch}"
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		error "Scratch branch does not exist locally: ${scratch_branch}"
	fi

	local current_branch
	current_branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD)"
	if [[ "$current_branch" != "$scratch_branch" ]]; then
		error "Cannot reset workflow: current branch ${current_branch} does not match scratchBranch ${scratch_branch}."
	fi

	local main_commit
	main_commit="$(git -C "$repo_root" rev-parse "$main_branch")"

	if ! git -C "$repo_root" reset --hard -q "$main_commit"; then
		error 'Git reset failed.'
	fi

	if ! (
		cd "$repo_root"
		git clean -f -d -q
	); then
		error 'Git clean failed.'
	fi

	local state_payload
	if [[ "$workflow_kind" == 'patch' ]]; then
		state_payload="$(build_patch_state_payload "$patch_description" "$main_branch" "$scratch_branch" '0')"
	else
		state_payload="$(build_issue_checkpoint_state_payload "$active_issue_number" "$active_issue_title" "$active_issue_url" "$main_branch" "$scratch_branch" '0')"
	fi
	workflow_state_json_helper 'set' "$workflow_state_file" "$state_payload" >/dev/null

	printf 'Reset %s to %s\n' "$scratch_branch" "$main_branch"
	printf 'checkpoint: 0\n'
	if [[ "$workflow_kind" == 'patch' ]]; then
		printf 'patch: %s\n' "$patch_description"
	else
		printf 'activeIssueNumber: %s\n' "$active_issue_number"
	fi
}

handle_promote() {
	local argument_count="$1"
	shift

	local commit_message="${1-}"
	if [[ "$argument_count" -ne 1 || -z "${commit_message//[[:space:]]/}" ]]; then
		error "Usage: ${script_name} promote \"<commit-message>\""
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"

	local workflow_state_file
	workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
	local state_json
	state_json="$(workflow_state_json_helper 'get' "$workflow_state_file")"

	local active_issue_number
	active_issue_number="$(workflow_state_get_field 'activeIssueNumber' "$state_json")"
	local patch_description
	patch_description="$(workflow_state_get_field 'patchDescription' "$state_json")"
	local workflow_kind
	workflow_kind="$(workflow_kind_from_state "$active_issue_number" "$patch_description")"
	if [[ "$workflow_kind" == 'inactive' ]]; then
		error 'Cannot promote workflow: no active issue is set.'
	fi

	local active_issue_title
	active_issue_title="$(workflow_state_get_field 'activeIssueTitle' "$state_json")"
	local active_issue_url
	active_issue_url="$(workflow_state_get_field 'activeIssueUrl' "$state_json")"
	local main_branch
	main_branch="$(workflow_state_get_field 'mainBranch' "$state_json")"
	local scratch_branch
	scratch_branch="$(workflow_state_get_field 'scratchBranch' "$state_json")"

	if [[ "$main_branch" == "$scratch_branch" ]]; then
		error 'Invalid workflow state: mainBranch and scratchBranch must be different.'
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		error "Main branch does not exist locally: ${main_branch}"
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		error "Scratch branch does not exist locally: ${scratch_branch}"
	fi

	local current_branch
	current_branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD)"
	if [[ "$current_branch" != "$scratch_branch" ]]; then
		error "Cannot promote workflow: current branch ${current_branch} does not match scratchBranch ${scratch_branch}."
	fi

	local porcelain_status
	porcelain_status="$(git -C "$repo_root" status --porcelain --untracked-files=all)"
	local staged unstaged untracked working_tree
	read -r staged unstaged untracked working_tree <<< "$(summarize_porcelain_status "$porcelain_status")"
	if [[ "$staged" == 'yes' || "$unstaged" == 'yes' || "$untracked" == 'yes' ]]; then
		error 'Cannot promote workflow: repository must be clean.'
	fi

	local counts
	counts="$(git -C "$repo_root" rev-list --left-right --count "${main_branch}...${scratch_branch}")"
	local main_only_count scratch_only_count
	IFS=$' \t' read -r main_only_count scratch_only_count <<< "$counts"

	if [[ "$main_only_count" -eq 0 && "$scratch_only_count" -eq 0 ]]; then
		error "Cannot promote workflow: ${scratch_branch} is equal to ${main_branch}."
	fi

	if [[ "$scratch_only_count" -eq 0 ]]; then
		error "Cannot promote workflow: ${scratch_branch} is behind ${main_branch}."
	fi

	if [[ "$main_only_count" -ne 0 ]]; then
		error "Cannot promote workflow: ${scratch_branch} and ${main_branch} have diverged."
	fi

	if ! git -C "$repo_root" checkout -q "$main_branch"; then
		error "Cannot promote workflow: failed to switch to ${main_branch}."
	fi

	if ! git -C "$repo_root" merge --squash "$scratch_branch"; then
		error 'Cannot promote workflow: squash merge failed.'
	fi

	if ! git -C "$repo_root" commit -q --message "$commit_message"; then
		error 'Cannot promote workflow: Git commit failed.'
	fi

	local promoted_commit
	promoted_commit="$(git -C "$repo_root" rev-parse HEAD)"

	if ! git -C "$repo_root" checkout -q "$scratch_branch"; then
		error "Cannot promote workflow: failed to switch back to ${scratch_branch}."
	fi

	if ! git -C "$repo_root" reset --hard -q "$promoted_commit"; then
		error "Cannot promote workflow: failed to reset ${scratch_branch} to promoted commit."
	fi

	local state_payload
	if [[ "$workflow_kind" == 'patch' ]]; then
		state_payload="$(build_patch_state_payload "$patch_description" "$main_branch" "$scratch_branch" '0')"
	else
		state_payload="$(build_issue_checkpoint_state_payload "$active_issue_number" "$active_issue_title" "$active_issue_url" "$main_branch" "$scratch_branch" '0')"
	fi
	workflow_state_json_helper 'set' "$workflow_state_file" "$state_payload" >/dev/null

	printf 'Promoted %s to %s\n' "$scratch_branch" "$main_branch"
	printf 'commit: %s\n' "$promoted_commit"
	printf 'checkpoint: 0\n'
	if [[ "$workflow_kind" == 'patch' ]]; then
		printf 'patch: %s\n' "$patch_description"
	else
		printf 'activeIssueNumber: %s\n' "$active_issue_number"
	fi
}

handle_complete() {
	local argument_count="$1"
	shift

	if [[ "$argument_count" -ne 0 ]]; then
		error "Usage: ${script_name} complete"
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"

	local workflow_state_file
	workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
	local state_json
	state_json="$(workflow_state_json_helper 'get' "$workflow_state_file")"

	local active_issue_number
	active_issue_number="$(workflow_state_get_field 'activeIssueNumber' "$state_json")"
	local patch_description
	patch_description="$(workflow_state_get_field 'patchDescription' "$state_json")"
	local workflow_kind
	workflow_kind="$(workflow_kind_from_state "$active_issue_number" "$patch_description")"
	if [[ "$workflow_kind" == 'inactive' ]]; then
		error 'Cannot complete workflow: no active issue is set.'
	fi

	local main_branch
	main_branch="$(workflow_state_get_field 'mainBranch' "$state_json")"
	local scratch_branch
	scratch_branch="$(workflow_state_get_field 'scratchBranch' "$state_json")"
	local checkpoint
	checkpoint="$(workflow_state_get_field 'checkpoint' "$state_json")"

	if [[ "$main_branch" == "$scratch_branch" ]]; then
		error 'Invalid workflow state: mainBranch and scratchBranch must be different.'
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		error "Main branch does not exist locally: ${main_branch}"
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		error "Scratch branch does not exist locally: ${scratch_branch}"
	fi

	local current_branch
	current_branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD)"
	if [[ "$current_branch" != "$scratch_branch" ]]; then
		error "Cannot complete workflow: current branch ${current_branch} does not match scratchBranch ${scratch_branch}."
	fi

	local porcelain_status
	porcelain_status="$(git -C "$repo_root" status --porcelain --untracked-files=all)"
	local staged unstaged untracked working_tree
	read -r staged unstaged untracked working_tree <<< "$(summarize_porcelain_status "$porcelain_status")"
	if [[ "$staged" == 'yes' || "$unstaged" == 'yes' || "$untracked" == 'yes' ]]; then
		error 'Cannot complete workflow: repository must be clean.'
	fi

	local counts
	counts="$(git -C "$repo_root" rev-list --left-right --count "${main_branch}...${scratch_branch}")"
	local main_only_count scratch_only_count
	IFS=$' \t' read -r main_only_count scratch_only_count <<< "$counts"

	if [[ "$main_only_count" -eq 0 && "$scratch_only_count" -eq 0 ]]; then
		:
	elif [[ "$main_only_count" -eq 0 ]]; then
		error "Cannot complete workflow: ${scratch_branch} is ahead of ${main_branch}."
	elif [[ "$scratch_only_count" -eq 0 ]]; then
		error "Cannot complete workflow: ${scratch_branch} is behind ${main_branch}."
	else
		error "Cannot complete workflow: ${scratch_branch} and ${main_branch} have diverged."
	fi

	if [[ "$checkpoint" != '0' ]]; then
		error "Cannot complete workflow: checkpoint must be 0 (current: ${checkpoint})."
	fi

	local state_payload
	state_payload="$(build_inactive_state_payload "$main_branch" "$scratch_branch")"
	workflow_state_json_helper 'set' "$workflow_state_file" "$state_payload" >/dev/null

	if [[ "$workflow_kind" == 'patch' ]]; then
		printf 'Completed patch: %s\n' "$patch_description"
	else
		printf 'Completed issue %s\n' "$active_issue_number"
	fi
	printf 'Workflow: inactive\n'
	printf 'mainBranch: %s\n' "$main_branch"
	printf 'scratchBranch: %s\n' "$scratch_branch"
	printf 'checkpoint: 0\n'
}

handle_start() {
	local argument_count="$1"
	shift

	local issue_number="${1:-}"

	if [[ "$argument_count" -ne 1 ]]; then
		error "Usage: ${script_name} start <issue-number>"
	fi

	if [[ ! "$issue_number" =~ ^[1-9][0-9]*$ ]]; then
		error 'issue-number must be a positive integer.'
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"

	local workflow_state_file
	workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
	local state_json
	state_json="$(workflow_state_json_helper 'get' "$workflow_state_file")"

	local active_issue_number
	active_issue_number="$(workflow_state_get_field 'activeIssueNumber' "$state_json")"
	local patch_description
	patch_description="$(workflow_state_get_field 'patchDescription' "$state_json")"
	if [[ -n "$active_issue_number" || -n "$patch_description" ]]; then
		if [[ -n "$active_issue_number" ]]; then
			error "Cannot start workflow: active issue ${active_issue_number} is already set."
		fi

		error "Cannot start workflow: active patch ${patch_description} is already set."
	fi

	local working_tree_status
	working_tree_status="$(git -C "$repo_root" status --porcelain --untracked-files=all)"
	if [[ -n "$working_tree_status" ]]; then
		error 'Working tree is not clean. Commit, stash, or remove changes before starting.'
	fi

	local main_branch
	main_branch="$(workflow_state_get_field 'mainBranch' "$state_json")"
	local scratch_branch
	scratch_branch="$(workflow_state_get_field 'scratchBranch' "$state_json")"

	if [[ "$main_branch" == "$scratch_branch" ]]; then
		error 'Invalid workflow state: mainBranch and scratchBranch must be different.'
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		error "Main branch does not exist locally: ${main_branch}"
	fi

	local issue_title=''
	local issue_url=''
	local issue_metadata
	issue_metadata="$(resolve_issue_metadata "$issue_number")"
	if [[ -n "$issue_metadata" ]]; then
		local issue_metadata_lines=()
		mapfile -t issue_metadata_lines <<< "$issue_metadata"
		issue_title="${issue_metadata_lines[0]:-}"
		issue_url="${issue_metadata_lines[1]:-}"
	fi

	local state_payload
	state_payload="$(build_start_state_payload "$issue_number" "$issue_title" "$issue_url" "$main_branch" "$scratch_branch")"
	workflow_state_json_helper 'validate' "$workflow_state_file" "$state_payload" >/dev/null

	git -C "$repo_root" checkout -q "$main_branch"
	local main_commit
	main_commit="$(git -C "$repo_root" rev-parse HEAD)"

	if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		git -C "$repo_root" checkout -q "$scratch_branch"
		git -C "$repo_root" reset --hard -q "$main_commit"
	else
		git -C "$repo_root" checkout -q -b "$scratch_branch" "$main_commit"
	fi
	workflow_state_json_helper 'set' "$workflow_state_file" "$state_payload" >/dev/null

	printf 'Started issue %s\n' "$issue_number"
	printf 'mainBranch: %s\n' "$main_branch"
	printf 'scratchBranch: %s\n' "$scratch_branch"
	printf 'checkpoint: 0\n'
}

handle_patch() {
	local argument_count="$1"
	shift

	local adopt_mode='no'
	local description=''

	if [[ "$argument_count" -eq 1 ]]; then
		if [[ "${1:-}" == '--adopt' ]]; then
			error "Usage: ${script_name} patch [--adopt] \"<description>\""
		fi

		description="${1:-}"
	elif [[ "$argument_count" -eq 2 && "${1:-}" == '--adopt' ]]; then
		adopt_mode='yes'
		description="${2:-}"
	else
		error "Usage: ${script_name} patch [--adopt] \"<description>\""
	fi

	if [[ -z "${description//[[:space:]]/}" ]]; then
		error 'patch description cannot be empty.'
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"

	local workflow_state_file
	workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
	local state_json
	state_json="$(workflow_state_json_helper 'get' "$workflow_state_file")"

	local active_issue_number
	active_issue_number="$(workflow_state_get_field 'activeIssueNumber' "$state_json")"
	local patch_description
	patch_description="$(workflow_state_get_field 'patchDescription' "$state_json")"
	if [[ -n "$active_issue_number" || -n "$patch_description" ]]; then
		if [[ -n "$active_issue_number" ]]; then
			error "Cannot patch workflow: active issue ${active_issue_number} is already set."
		fi

		error "Cannot patch workflow: active patch ${patch_description} is already set."
	fi

	local main_branch
	main_branch="$(workflow_state_get_field 'mainBranch' "$state_json")"
	local scratch_branch
	scratch_branch="$(workflow_state_get_field 'scratchBranch' "$state_json")"

	if [[ "$main_branch" == "$scratch_branch" ]]; then
		error 'Invalid workflow state: mainBranch and scratchBranch must be different.'
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		error "Main branch does not exist locally: ${main_branch}"
	fi

	if [[ "$adopt_mode" == 'yes' ]]; then
		local current_branch
		current_branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD)"
		if [[ "$current_branch" != "$scratch_branch" ]]; then
			error "Cannot patch workflow: current branch ${current_branch} does not match scratchBranch ${scratch_branch}."
		fi

		if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
			error "Scratch branch does not exist locally: ${scratch_branch}"
		fi

		local checkpoint
		checkpoint="$(count_numbered_scratch_checkpoints "$repo_root" "$main_branch" "$scratch_branch")"

		local state_payload
		state_payload="$(build_patch_state_payload "$description" "$main_branch" "$scratch_branch" "$checkpoint")"
		workflow_state_json_helper 'set' "$workflow_state_file" "$state_payload" >/dev/null

		printf 'Adopted patch: %s\n' "$description"
		printf 'mainBranch: %s\n' "$main_branch"
		printf 'scratchBranch: %s\n' "$scratch_branch"
		printf 'checkpoint: %s\n' "$checkpoint"
		return 0
	fi

	local working_tree_status
	working_tree_status="$(git -C "$repo_root" status --porcelain --untracked-files=all)"
	if [[ -n "$working_tree_status" ]]; then
		error 'Working tree is not clean. Commit, stash, or remove changes before starting.'
	fi

	git -C "$repo_root" checkout -q "$main_branch"
	local main_commit
	main_commit="$(git -C "$repo_root" rev-parse HEAD)"

	if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		git -C "$repo_root" checkout -q "$scratch_branch"
		git -C "$repo_root" reset --hard -q "$main_commit"
	else
		git -C "$repo_root" checkout -q -b "$scratch_branch" "$main_commit"
	fi

	local state_payload
	state_payload="$(build_patch_state_payload "$description" "$main_branch" "$scratch_branch" '0')"
	workflow_state_json_helper 'set' "$workflow_state_file" "$state_payload" >/dev/null

	printf 'Started patch: %s\n' "$description"
	printf 'mainBranch: %s\n' "$main_branch"
	printf 'scratchBranch: %s\n' "$scratch_branch"
	printf 'checkpoint: 0\n'
}

handle_block() {
	local argument_count="$1"
	shift

	local reason="${1:-}"
	if [[ "$argument_count" -ne 1 || -z "${reason//[[:space:]]/}" ]]; then
		error "Usage: ${script_name} block \"<reason>\""
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"

	local workflow_state_file
	workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
	local state_json
	state_json="$(workflow_state_json_helper 'get' "$workflow_state_file")"

	local active_issue_number
	active_issue_number="$(workflow_state_get_field 'activeIssueNumber' "$state_json")"
	local patch_description
	patch_description="$(workflow_state_get_field 'patchDescription' "$state_json")"
	local workflow_kind
	workflow_kind="$(workflow_kind_from_state "$active_issue_number" "$patch_description")"
	if [[ "$workflow_kind" == 'inactive' ]]; then
		error 'Cannot block workflow: no active issue is set.'
	fi
	if [[ "$workflow_kind" == 'patch' ]]; then
		error 'Cannot block workflow: patch workflows are not supported.'
	fi

	local main_branch
	main_branch="$(workflow_state_get_field 'mainBranch' "$state_json")"
	local scratch_branch
	scratch_branch="$(workflow_state_get_field 'scratchBranch' "$state_json")"
	local checkpoint
	checkpoint="$(workflow_state_get_field 'checkpoint' "$state_json")"

	if [[ "$main_branch" == "$scratch_branch" ]]; then
		error 'Invalid workflow state: mainBranch and scratchBranch must be different.'
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		error "Main branch does not exist locally: ${main_branch}"
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		error "Scratch branch does not exist locally: ${scratch_branch}"
	fi

	local porcelain_status
	porcelain_status="$(git -C "$repo_root" status --porcelain --untracked-files=all)"
	local staged unstaged untracked working_tree
	read -r staged unstaged untracked working_tree <<< "$(summarize_porcelain_status "$porcelain_status")"
	if [[ "$staged" == 'yes' || "$unstaged" == 'yes' || "$untracked" == 'yes' ]]; then
		error 'Cannot block workflow: repository must be clean.'
	fi

	local counts
	counts="$(git -C "$repo_root" rev-list --left-right --count "${main_branch}...${scratch_branch}")"
	local main_only_count scratch_only_count
	IFS=$' \t' read -r main_only_count scratch_only_count <<< "$counts"
	if [[ "$main_only_count" -ne 0 || "$scratch_only_count" -ne 0 ]]; then
		error "Cannot block workflow: ${scratch_branch} must equal ${main_branch}."
	fi

	if [[ "$checkpoint" != '0' ]]; then
		error "Cannot block workflow: checkpoint must be 0 (current: ${checkpoint})."
	fi

	local issue_details
	issue_details="$(resolve_issue_details_with_labels "$active_issue_number")"
	local issue_lines=()
	mapfile -t issue_lines <<< "$issue_details"
	local issue_title="${issue_lines[0]:-}"
	local issue_url="${issue_lines[1]:-}"
	local issue_labels_csv="${issue_lines[2]:-}"

	local blocked_workflows_file
	blocked_workflows_file="$(blocked_workflows_file_for_repo_root "$repo_root")"
	local blocked_before_json
	blocked_before_json="$(blocked_workflows_json_helper 'get' "$blocked_workflows_file")"

	local blocked_at
	blocked_at="$(now_utc_iso_timestamp)"
	local blocked_record_payload
	blocked_record_payload="$(build_blocked_workflow_record_payload "$active_issue_number" "$issue_title" "$issue_url" "$reason" "$blocked_at")"
	blocked_workflows_json_helper 'upsert' "$blocked_workflows_file" "$blocked_record_payload" >/dev/null

	local github_failed='no'
	set +e
	reconcile_github_workflow_label "$active_issue_number" 'blocked' "$issue_labels_csv"
	local reconcile_status=$?
	set -e
	if [[ "$reconcile_status" -ne 0 ]]; then
		github_failed='yes'
	fi

	if [[ "$github_failed" == 'yes' ]]; then
		set +e
		blocked_workflows_json_helper 'set' "$blocked_workflows_file" "$blocked_before_json" >/dev/null
		local restore_status=$?
		set -e
		if [[ "$restore_status" -ne 0 ]]; then
			printf '%s: Warning: failed to remove provisional blocked record for issue %s.\n' "$script_name" "$active_issue_number" >&2
		fi
		error "Cannot block workflow: failed to synchronize GitHub labels for issue ${active_issue_number}."
	fi

	local inactive_payload
	inactive_payload="$(build_inactive_state_payload "$main_branch" "$scratch_branch")"
	workflow_state_json_helper 'set' "$workflow_state_file" "$inactive_payload" >/dev/null

	printf 'Blocked issue %s\n' "$active_issue_number"
	printf 'reason: %s\n' "$reason"
	printf 'Workflow: inactive\n'
	printf 'mainBranch: %s\n' "$main_branch"
	printf 'scratchBranch: %s\n' "$scratch_branch"
	printf 'checkpoint: 0\n'
}

handle_resume() {
	local argument_count="$1"
	shift

	local issue_number="${1:-}"
	if [[ "$argument_count" -ne 1 ]]; then
		error "Usage: ${script_name} resume <ticket-number>"
	fi

	if [[ ! "$issue_number" =~ ^[1-9][0-9]*$ ]]; then
		error 'ticket-number must be a positive integer.'
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"

	local workflow_state_file
	workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
	local state_json
	state_json="$(workflow_state_json_helper 'get' "$workflow_state_file")"

	local active_issue_number
	active_issue_number="$(workflow_state_get_field 'activeIssueNumber' "$state_json")"
	local patch_description
	patch_description="$(workflow_state_get_field 'patchDescription' "$state_json")"
	if [[ -n "$active_issue_number" || -n "$patch_description" ]]; then
		if [[ -n "$active_issue_number" ]]; then
			error "Cannot resume workflow: active issue ${active_issue_number} is already set."
		fi
		error "Cannot resume workflow: active patch ${patch_description} is already set."
	fi

	local main_branch
	main_branch="$(workflow_state_get_field 'mainBranch' "$state_json")"
	local scratch_branch
	scratch_branch="$(workflow_state_get_field 'scratchBranch' "$state_json")"

	if [[ "$main_branch" == "$scratch_branch" ]]; then
		error 'Invalid workflow state: mainBranch and scratchBranch must be different.'
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$main_branch"; then
		error "Main branch does not exist locally: ${main_branch}"
	fi

	if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$scratch_branch"; then
		error "Scratch branch does not exist locally: ${scratch_branch}"
	fi

	local porcelain_status
	porcelain_status="$(git -C "$repo_root" status --porcelain --untracked-files=all)"
	local staged unstaged untracked working_tree
	read -r staged unstaged untracked working_tree <<< "$(summarize_porcelain_status "$porcelain_status")"
	if [[ "$staged" == 'yes' || "$unstaged" == 'yes' || "$untracked" == 'yes' ]]; then
		error 'Cannot resume workflow: repository must be clean.'
	fi

	local counts
	counts="$(git -C "$repo_root" rev-list --left-right --count "${main_branch}...${scratch_branch}")"
	local main_only_count scratch_only_count
	IFS=$' \t' read -r main_only_count scratch_only_count <<< "$counts"
	if [[ "$main_only_count" -ne 0 || "$scratch_only_count" -ne 0 ]]; then
		error "Cannot resume workflow: ${scratch_branch} must equal ${main_branch}."
	fi

	local blocked_workflows_file
	blocked_workflows_file="$(blocked_workflows_file_for_repo_root "$repo_root")"
	local blocked_record_json
	blocked_record_json="$(blocked_workflows_json_helper 'get-record' "$blocked_workflows_file" "$issue_number")"
	if [[ -z "$blocked_record_json" ]]; then
		error "Cannot resume workflow: no blocked record exists for issue ${issue_number}."
	fi

	local blocked_record_fields
	blocked_record_fields="$(python3 - "$blocked_record_json" <<'PY'
import json
import sys

data = json.loads(sys.argv[1])
print(data.get('issueTitle', ''))
print(data.get('issueUrl', ''))
PY
)"
	local blocked_record_lines=()
	mapfile -t blocked_record_lines <<< "$blocked_record_fields"
	local blocked_issue_title="${blocked_record_lines[0]:-}"
	local blocked_issue_url="${blocked_record_lines[1]:-}"

	local issue_details
	issue_details="$(resolve_issue_details_with_labels "$issue_number")"
	local issue_lines=()
	mapfile -t issue_lines <<< "$issue_details"
	local issue_labels_csv="${issue_lines[2]:-}"

	reconcile_github_workflow_label "$issue_number" 'active' "$issue_labels_csv"

	local resumed_state_payload
	resumed_state_payload="$(build_start_state_payload "$issue_number" "$blocked_issue_title" "$blocked_issue_url" "$main_branch" "$scratch_branch")"
	workflow_state_json_helper 'set' "$workflow_state_file" "$resumed_state_payload" >/dev/null

	blocked_workflows_json_helper 'remove' "$blocked_workflows_file" "$issue_number" >/dev/null

	printf 'Resumed issue %s\n' "$issue_number"
	printf 'mainBranch: %s\n' "$main_branch"
	printf 'scratchBranch: %s\n' "$scratch_branch"
	printf 'checkpoint: 0\n'
}

validate_config_key() {
	local command="$1"
	local key="$2"

	if [[ "$key" != 'out' ]]; then
		error "Unknown configuration key for ${command}: ${key}. Supported key: out."
	fi
}

validate_out_value() {
	local value="$1"

	if [[ -z "${value//[[:space:]]/}" ]]; then
		error 'out value cannot be empty.'
	fi
}

config_json_helper() {
	local operation="$1"
	local config_file="$2"
	local key="$3"
	local value="${4-}"

	python3 - "$script_name" "$operation" "$config_file" "$key" "$value" <<'PY'
import json
import os
import sys
import tempfile
from pathlib import Path


def fail(message):
	print(f"{script_name}: {message}", file=sys.stderr)
	sys.exit(1)


script_name = sys.argv[1]
operation = sys.argv[2]
config_path = Path(sys.argv[3])
key = sys.argv[4]
value = sys.argv[5]

if key != 'out':
	fail(f"Unknown configuration key for {operation}: {key}. Supported key: out.")


def load_config():
	if not config_path.exists():
		return {}

	try:
		data = json.loads(config_path.read_text(encoding='utf-8'))
	except json.JSONDecodeError as exc:
		fail(f"Invalid JSON in {config_path}: {exc.msg} (line {exc.lineno}, column {exc.colno})")
	if not isinstance(data, dict):
		fail(f"Invalid configuration in {config_path}: expected a JSON object.")

	unknown_keys = sorted(name for name in data if name != 'out')
	if unknown_keys:
		fail(f"Unknown configuration key(s) in {config_path}: {', '.join(unknown_keys)}")

	if 'out' in data:
		out_value = data['out']
		if not isinstance(out_value, str):
			fail(f"Invalid configuration in {config_path}: out must be a string.")
		if not out_value.strip():
			fail(f"Invalid configuration in {config_path}: out cannot be empty.")

	return data


def write_config(data):
	config_path.parent.mkdir(parents=True, exist_ok=True)
	with tempfile.NamedTemporaryFile(
		mode='w',
		encoding='utf-8',
		dir=config_path.parent,
		prefix=f'{config_path.name}.tmp-',
		delete=False,
	) as handle:
		json.dump(data, handle, indent=2)
		handle.write('\n')
		temporary_path = Path(handle.name)
	try:
		os.replace(temporary_path, config_path)
	except Exception:
		try:
			temporary_path.unlink()
		except FileNotFoundError:
			pass
		raise


if operation == 'get':
	config = load_config()
	if 'out' not in config:
		sys.exit(0)
	print(config['out'])
elif operation == 'set':
	if not value.strip():
		fail('out value cannot be empty.')
	config = load_config()
	config['out'] = value
	write_config(config)
	print(f'out: {value}')
elif operation == 'unset':
	config = load_config()
	if 'out' not in config:
		print('out: not configured')
		sys.exit(0)
	del config['out']
	if config:
		write_config(config)
	elif config_path.exists():
		config_path.unlink()
	print('out: not configured')
else:
	fail(f'Unknown configuration operation: {operation}')
PY
}

workflow_state_json_helper() {
	local operation="$1"
	local workflow_state_file="$2"
	local payload="${3-}"

	python3 - "$script_name" "$operation" "$workflow_state_file" "$payload" <<'PY'
import json
import os
import sys
import tempfile
from pathlib import Path


def fail(message):
	print(f"{script_name}: {message}", file=sys.stderr)
	sys.exit(1)


script_name = sys.argv[1]
operation = sys.argv[2]
state_path = Path(sys.argv[3])
payload = sys.argv[4]

DEFAULTS = {
	'mainBranch': 'main',
	'scratchBranch': 'scratch',
	'checkpoint': 0,
}

ALLOWED_KEYS = {
	'activeIssueNumber',
	'activeIssueTitle',
	'activeIssueUrl',
	'patchDescription',
	'mainBranch',
	'scratchBranch',
	'checkpoint',
}


def is_int(value):
	return isinstance(value, int) and not isinstance(value, bool)


def normalize_and_validate(state_data, context):
	if not isinstance(state_data, dict):
		fail(f"Invalid workflow state in {context}: expected a JSON object.")

	unknown_keys = sorted(name for name in state_data if name not in ALLOWED_KEYS)
	if unknown_keys:
		fail(f"Unknown workflow state key(s) in {context}: {', '.join(unknown_keys)}")

	normalized = {
		'mainBranch': DEFAULTS['mainBranch'],
		'scratchBranch': DEFAULTS['scratchBranch'],
		'checkpoint': DEFAULTS['checkpoint'],
	}

	if 'mainBranch' in state_data:
		main_branch = state_data['mainBranch']
		if not isinstance(main_branch, str):
			fail(f"Invalid workflow state in {context}: mainBranch must be a string.")
		main_branch = main_branch.strip()
		if not main_branch:
			fail(f"Invalid workflow state in {context}: mainBranch cannot be empty.")
		normalized['mainBranch'] = main_branch

	if 'scratchBranch' in state_data:
		scratch_branch = state_data['scratchBranch']
		if not isinstance(scratch_branch, str):
			fail(f"Invalid workflow state in {context}: scratchBranch must be a string.")
		scratch_branch = scratch_branch.strip()
		if not scratch_branch:
			fail(f"Invalid workflow state in {context}: scratchBranch cannot be empty.")
		normalized['scratchBranch'] = scratch_branch

	if 'checkpoint' in state_data:
		checkpoint = state_data['checkpoint']
		if not is_int(checkpoint) or checkpoint < 0:
			fail(f"Invalid workflow state in {context}: checkpoint must be a non-negative integer.")
		normalized['checkpoint'] = checkpoint

	has_issue_number = 'activeIssueNumber' in state_data
	has_issue_title = 'activeIssueTitle' in state_data
	has_issue_url = 'activeIssueUrl' in state_data
	has_patch_description = 'patchDescription' in state_data

	if has_issue_number and has_patch_description:
		fail(f"Invalid workflow state in {context}: activeIssueNumber and patchDescription cannot both be set.")

	if has_issue_number:
		issue_number = state_data['activeIssueNumber']
		if not is_int(issue_number) or issue_number <= 0:
			fail(f"Invalid workflow state in {context}: activeIssueNumber must be a positive integer.")
		normalized['activeIssueNumber'] = issue_number

	if has_issue_title:
		issue_title = state_data['activeIssueTitle']
		if not isinstance(issue_title, str):
			fail(f"Invalid workflow state in {context}: activeIssueTitle must be a string.")
		issue_title = issue_title.strip()
		if not issue_title:
			fail(f"Invalid workflow state in {context}: activeIssueTitle cannot be empty.")
		normalized['activeIssueTitle'] = issue_title

	if has_issue_title and not has_issue_number:
		fail(f"Invalid workflow state in {context}: activeIssueTitle requires activeIssueNumber.")

	if has_issue_url:
		issue_url = state_data['activeIssueUrl']
		if not isinstance(issue_url, str):
			fail(f"Invalid workflow state in {context}: activeIssueUrl must be a string.")
		issue_url = issue_url.strip()
		if not issue_url:
			fail(f"Invalid workflow state in {context}: activeIssueUrl cannot be empty.")
		from urllib.parse import urlparse
		parsed_url = urlparse(issue_url)
		if parsed_url.scheme not in ('http', 'https') or not parsed_url.netloc:
			fail(f"Invalid workflow state in {context}: activeIssueUrl must be a valid HTTP(S) URL.")
		normalized['activeIssueUrl'] = issue_url

	if has_issue_url and not has_issue_number:
		fail(f"Invalid workflow state in {context}: activeIssueUrl requires activeIssueNumber.")

	if has_patch_description:
		patch_description = state_data['patchDescription']
		if not isinstance(patch_description, str):
			fail(f"Invalid workflow state in {context}: patchDescription must be a string.")
		patch_description = patch_description.strip()
		if not patch_description:
			fail(f"Invalid workflow state in {context}: patchDescription cannot be empty.")
		normalized['patchDescription'] = patch_description

	return normalized


def load_state():
	if not state_path.exists():
		return dict(DEFAULTS)

	try:
		raw_state = json.loads(state_path.read_text(encoding='utf-8'))
	except json.JSONDecodeError as exc:
		fail(f"Invalid JSON in {state_path}: {exc.msg} (line {exc.lineno}, column {exc.colno})")

	return normalize_and_validate(raw_state, str(state_path))


def write_state(state_data):
	temporary_path = None
	try:
		state_path.parent.mkdir(parents=True, exist_ok=True)
		with tempfile.NamedTemporaryFile(
			mode='w',
			encoding='utf-8',
			dir=state_path.parent,
			prefix=f'{state_path.name}.tmp-',
			delete=False,
		) as handle:
			json.dump(state_data, handle, indent=2)
			handle.write('\n')
			temporary_path = Path(handle.name)
		os.replace(temporary_path, state_path)
	except Exception as exc:
		if temporary_path is not None:
			try:
				temporary_path.unlink()
			except FileNotFoundError:
				pass
		fail(f"Cannot write workflow state to {state_path}: {exc}")


if operation == 'get':
	state = load_state()
	print(json.dumps(state, indent=2))
elif operation == 'set':
	try:
		payload_data = json.loads(payload)
	except json.JSONDecodeError as exc:
		fail(f"Invalid JSON payload for workflow state: {exc.msg} (line {exc.lineno}, column {exc.colno})")
	state = normalize_and_validate(payload_data, 'state payload')
	write_state(state)
	print(json.dumps(state, indent=2))
elif operation == 'validate':
	try:
		payload_data = json.loads(payload)
	except json.JSONDecodeError as exc:
		fail(f"Invalid JSON payload for workflow state: {exc.msg} (line {exc.lineno}, column {exc.colno})")
	state = normalize_and_validate(payload_data, 'state payload')
	print(json.dumps(state, indent=2))
elif operation == 'clear':
	if state_path.exists():
		state_path.unlink()
	print(json.dumps(dict(DEFAULTS), indent=2))
else:
	fail(f"Unknown workflow state operation: {operation}")
PY
}

blocked_workflows_json_helper() {
	local operation="$1"
	local blocked_workflows_file="$2"
	local payload="${3-}"

	python3 - "$script_name" "$operation" "$blocked_workflows_file" "$payload" <<'PY'
import json
import os
import sys
import tempfile
from datetime import datetime
from pathlib import Path
from urllib.parse import urlparse


def fail(message):
	print(f"{script_name}: {message}", file=sys.stderr)
	sys.exit(1)


script_name = sys.argv[1]
operation = sys.argv[2]
blocked_path = Path(sys.argv[3])
payload = sys.argv[4]

DEFAULTS = {
	'blockedWorkflows': [],
}

ALLOWED_TOP_LEVEL_KEYS = {
	'blockedWorkflows',
}

ALLOWED_RECORD_KEYS = {
	'issueNumber',
	'issueTitle',
	'issueUrl',
	'reason',
	'blockedAt',
}


def is_int(value):
	return isinstance(value, int) and not isinstance(value, bool)


def normalize_record(record_data, context):
	if not isinstance(record_data, dict):
		fail(f"Invalid blocked workflow record in {context}: expected a JSON object.")

	unknown_keys = sorted(name for name in record_data if name not in ALLOWED_RECORD_KEYS)
	if unknown_keys:
		fail(f"Unknown blocked workflow record key(s) in {context}: {', '.join(unknown_keys)}")

	missing = [name for name in ('issueNumber', 'issueTitle', 'issueUrl', 'reason', 'blockedAt') if name not in record_data]
	if missing:
		fail(f"Invalid blocked workflow record in {context}: missing required key(s): {', '.join(missing)}")

	issue_number = record_data['issueNumber']
	if not is_int(issue_number) or issue_number <= 0:
		fail(f"Invalid blocked workflow record in {context}: issueNumber must be a positive integer.")

	issue_title = record_data['issueTitle']
	if not isinstance(issue_title, str):
		fail(f"Invalid blocked workflow record in {context}: issueTitle must be a string.")
	issue_title = issue_title.strip()
	if not issue_title:
		fail(f"Invalid blocked workflow record in {context}: issueTitle cannot be empty.")

	issue_url = record_data['issueUrl']
	if not isinstance(issue_url, str):
		fail(f"Invalid blocked workflow record in {context}: issueUrl must be a string.")
	issue_url = issue_url.strip()
	if not issue_url:
		fail(f"Invalid blocked workflow record in {context}: issueUrl cannot be empty.")
	parsed_url = urlparse(issue_url)
	if parsed_url.scheme not in ('http', 'https') or not parsed_url.netloc:
		fail(f"Invalid blocked workflow record in {context}: issueUrl must be a valid HTTP(S) URL.")

	reason = record_data['reason']
	if not isinstance(reason, str):
		fail(f"Invalid blocked workflow record in {context}: reason must be a string.")
	reason = reason.strip()
	if not reason:
		fail(f"Invalid blocked workflow record in {context}: reason cannot be empty.")

	blocked_at = record_data['blockedAt']
	if not isinstance(blocked_at, str):
		fail(f"Invalid blocked workflow record in {context}: blockedAt must be a string.")
	blocked_at = blocked_at.strip()
	if not blocked_at:
		fail(f"Invalid blocked workflow record in {context}: blockedAt cannot be empty.")
	iso_value = blocked_at.replace('Z', '+00:00')
	try:
		datetime.fromisoformat(iso_value)
	except ValueError:
		fail(f"Invalid blocked workflow record in {context}: blockedAt must be an ISO-8601 timestamp.")

	return {
		'issueNumber': issue_number,
		'issueTitle': issue_title,
		'issueUrl': issue_url,
		'reason': reason,
		'blockedAt': blocked_at,
	}


def normalize_document(document_data, context):
	if not isinstance(document_data, dict):
		fail(f"Invalid blocked workflows in {context}: expected a JSON object.")

	unknown_keys = sorted(name for name in document_data if name not in ALLOWED_TOP_LEVEL_KEYS)
	if unknown_keys:
		fail(f"Unknown blocked workflow key(s) in {context}: {', '.join(unknown_keys)}")

	records = document_data.get('blockedWorkflows', [])
	if not isinstance(records, list):
		fail(f"Invalid blocked workflows in {context}: blockedWorkflows must be an array.")

	normalized_records = []
	seen_issue_numbers = set()
	for index, record in enumerate(records):
		normalized_record = normalize_record(record, f"{context} record #{index + 1}")
		issue_number = normalized_record['issueNumber']
		if issue_number in seen_issue_numbers:
			fail(f"Invalid blocked workflows in {context}: duplicate issueNumber {issue_number}.")
		seen_issue_numbers.add(issue_number)
		normalized_records.append(normalized_record)

	return {
		'blockedWorkflows': normalized_records,
	}


def load_document():
	if not blocked_path.exists():
		return dict(DEFAULTS)

	try:
		raw_document = json.loads(blocked_path.read_text(encoding='utf-8'))
	except json.JSONDecodeError as exc:
		fail(f"Invalid JSON in {blocked_path}: {exc.msg} (line {exc.lineno}, column {exc.colno})")

	return normalize_document(raw_document, str(blocked_path))


def write_document(document_data):
	temporary_path = None
	try:
		blocked_path.parent.mkdir(parents=True, exist_ok=True)
		with tempfile.NamedTemporaryFile(
			mode='w',
			encoding='utf-8',
			dir=blocked_path.parent,
			prefix=f'{blocked_path.name}.tmp-',
			delete=False,
		) as handle:
			json.dump(document_data, handle, indent=2)
			handle.write('\n')
			temporary_path = Path(handle.name)
		os.replace(temporary_path, blocked_path)
	except Exception as exc:
		if temporary_path is not None:
			try:
				temporary_path.unlink()
			except FileNotFoundError:
				pass
		fail(f"Cannot write blocked workflows to {blocked_path}: {exc}")


if operation == 'get':
	document = load_document()
	print(json.dumps(document, indent=2))
elif operation == 'set':
	try:
		payload_data = json.loads(payload)
	except json.JSONDecodeError as exc:
		fail(f"Invalid JSON payload for blocked workflows: {exc.msg} (line {exc.lineno}, column {exc.colno})")
	document = normalize_document(payload_data, 'blocked workflows payload')
	write_document(document)
	print(json.dumps(document, indent=2))
elif operation == 'validate':
	try:
		payload_data = json.loads(payload)
	except json.JSONDecodeError as exc:
		fail(f"Invalid JSON payload for blocked workflows: {exc.msg} (line {exc.lineno}, column {exc.colno})")
	document = normalize_document(payload_data, 'blocked workflows payload')
	print(json.dumps(document, indent=2))
elif operation == 'upsert':
	try:
		record_payload = json.loads(payload)
	except json.JSONDecodeError as exc:
		fail(f"Invalid JSON payload for blocked workflow record: {exc.msg} (line {exc.lineno}, column {exc.colno})")
	normalized_record = normalize_record(record_payload, 'blocked workflow payload')
	document = load_document()
	updated_records = []
	replaced = False
	for record in document['blockedWorkflows']:
		if record['issueNumber'] == normalized_record['issueNumber']:
			updated_records.append(normalized_record)
			replaced = True
		else:
			updated_records.append(record)
	if not replaced:
		updated_records.append(normalized_record)
	document = normalize_document({'blockedWorkflows': updated_records}, 'blocked workflows upsert result')
	write_document(document)
	print(json.dumps(document, indent=2))
elif operation == 'remove':
	try:
		issue_number = int(payload)
	except ValueError:
		fail('Invalid blocked workflow issue number payload: expected a positive integer.')
	if issue_number <= 0:
		fail('Invalid blocked workflow issue number payload: expected a positive integer.')
	document = load_document()
	updated_records = [record for record in document['blockedWorkflows'] if record['issueNumber'] != issue_number]
	document = normalize_document({'blockedWorkflows': updated_records}, 'blocked workflows remove result')
	write_document(document)
	print(json.dumps(document, indent=2))
elif operation == 'get-record':
	try:
		issue_number = int(payload)
	except ValueError:
		fail('Invalid blocked workflow issue number payload: expected a positive integer.')
	if issue_number <= 0:
		fail('Invalid blocked workflow issue number payload: expected a positive integer.')
	document = load_document()
	for record in document['blockedWorkflows']:
		if record['issueNumber'] == issue_number:
			print(json.dumps(record, indent=2))
			sys.exit(0)
	print('')
else:
	fail(f"Unknown blocked workflows operation: {operation}")
PY
}

print_config_not_configured() {
	printf 'out: not configured\n'
}

print_config_value() {
	local value="$1"
	printf '%s\n' "$value"
}

handle_config_get() {
	local key="${1:-}"
	local extra="${2:-}"

	if [[ -z "$key" || -n "$extra" ]]; then
		error "Usage: ${script_name} get out"
	fi

	validate_config_key 'get' "$key"

	local repo_root
	repo_root="$(resolve_repo_root)"
	local config_file
	config_file="$(config_file_for_repo_root "$repo_root")"

	local value
	local helper_status=0
	set +e
	value="$(config_json_helper 'get' "$config_file" "$key")"
	helper_status=$?
	set -e
	if [[ "$helper_status" -eq 0 ]]; then
		if [[ -n "$value" ]]; then
			print_config_value "$value"
		else
			print_config_not_configured
		fi
	else
		return "$helper_status"
	fi
}

handle_config_set() {
	local assignment="${1:-}"
	local extra="${2:-}"

	if [[ -z "$assignment" || -n "$extra" ]]; then
		error "Usage: ${script_name} set out=<path>"
	fi

	local key="${assignment%%=*}"
	local value="${assignment#*=}"
	if [[ "$key" != "$assignment" ]]; then
		validate_config_key 'set' "$key"
		validate_out_value "$value"
	else
		error "Usage: ${script_name} set out=<path>"
	fi

	local repo_root
	repo_root="$(resolve_repo_root)"
	local config_file
	config_file="$(config_file_for_repo_root "$repo_root")"

	config_json_helper 'set' "$config_file" 'out' "$value"
}

handle_config_unset() {
	local key="${1:-}"
	local extra="${2:-}"

	if [[ -z "$key" || -n "$extra" ]]; then
		error "Usage: ${script_name} unset out"
	fi

	validate_config_key 'unset' "$key"

	local repo_root
	repo_root="$(resolve_repo_root)"
	local config_file
	config_file="$(config_file_for_repo_root "$repo_root")"

	config_json_helper 'unset' "$config_file" "$key"
}

print_help() {
	cat <<EOF
Usage: ${script_name} <command> [options]

Manage an issue-focused development workflow using permanent main history
and disposable scratch checkpoints.

Commands:
  start      Begin work on an issue and reset scratch from main.
	patch      Begin or adopt a local patch workflow on scratch.
  status     Show the active issue and current repository state.
  review     Generate the cumulative change package for review.
  commit     Create the next numbered checkpoint on scratch.
  reset      Discard scratch work and restore it from main.
  promote    Squash scratch into one permanent commit on main.
  complete   Clear the completed local workflow.
	block      Block the active issue workflow and release the active slot.
	resume     Resume a previously blocked issue workflow.
  get        Read a repository setting.
  set        Change a repository setting.
  unset      Remove a repository setting.
  help       Show this help.

Run \`${script_name} <command> --help\` for command-specific help.
EOF
}

is_help_flag() {
	case "$1" in
		-h|--help)
			return 0
			;;
		*)
			return 1
			;;
	esac
}

print_command_help() {
	local command="$1"

	case "$command" in
		start)
			cat <<EOF
Usage: ${script_name} start <issue-number>

Begin work on an issue by resetting scratch to main, checking out scratch,
and recording the active issue.

Options:
  -h, --help  Show this help.
EOF
			;;
		status)
			cat <<EOF
Usage: ${script_name} status [-v|--verbose]

Show the active issue, current branch, and repository deviations.

Options:
  -v, --verbose  Show complete workflow and Git details.
  -h, --help     Show this help.
EOF
			;;
		patch)
			cat <<EOF
Usage: ${script_name} patch "<description>"
       ${script_name} patch --adopt "<description>"

Start a local patch workflow for small, self-contained changes, or adopt
existing scratch work without changing commits, index, or working tree.

Options:
  --adopt      Adopt existing work on scratch and preserve repository state.
  -h, --help   Show this help.
EOF
			;;
		review)
			cat <<EOF
Usage: ${script_name} review

Generate a cumulative review package for all scratch and working-tree
changes relative to main.

Options:
  -h, --help  Show this help.
EOF
			;;
		commit)
			cat <<EOF
Usage: ${script_name} commit

Create the next numbered checkpoint commit on scratch.

Options:
  -h, --help  Show this help.
EOF
			;;
		reset)
			cat <<EOF
Usage: ${script_name} reset

Discard scratch commits and working-tree changes by resetting scratch to
main while preserving the active issue.

Options:
  -h, --help  Show this help.
EOF
			;;
		promote)
			cat <<EOF
Usage: ${script_name} promote "<commit-message>"

Squash the complete scratch change into one permanent commit on main, then
reset scratch to the promoted main commit.

Options:
  -h, --help  Show this help.
EOF
			;;
		complete)
			cat <<EOF
Usage: ${script_name} complete

Clear the active local workflow after scratch and main are synchronized.

Options:
  -h, --help  Show this help.
EOF
			;;
		block)
			cat <<EOF
Usage: ${script_name} block "<reason>"

Block an active issue workflow, keep the issue open, and release the
local active workflow slot.

Options:
  -h, --help  Show this help.
EOF
			;;
		resume)
			cat <<EOF
Usage: ${script_name} resume <ticket-number>

Resume a blocked issue workflow and restore it as the local active issue.

Options:
  -h, --help  Show this help.
EOF
			;;
		get)
			cat <<EOF
Usage: ${script_name} get out

Show the configured operational output destination.

Options:
  -h, --help  Show this help.
EOF
			;;
		set)
			cat <<EOF
Usage: ${script_name} set out=<path>

Configure operational command output to replace the specified file.

Options:
  -h, --help  Show this help.
EOF
			;;
		unset)
			cat <<EOF
Usage: ${script_name} unset out

Remove the configured operational output destination.

Options:
  -h, --help  Show this help.
EOF
			;;
		help)
			cat <<EOF
Usage: ${script_name} help

Show top-level command help.

Options:
  -h, --help  Show this help.
EOF
			;;
		*)
			error "Unknown command help target: ${command}"
			;;
	esac
}

print_unknown_command() {
	local command="$1"
	printf '%s: unknown command: %s\n' "$script_name" "$command" >&2
	printf 'Run %s help for usage.\n' "$script_name" >&2
}

main() {
	local command="${1:-}"
	local first_argument="${2:-}"
	local second_argument="${3:-}"
	local argument_count=0
	if [[ $# -gt 0 ]]; then
		argument_count=$(( $# - 1 ))
	fi

	if [[ $# -eq 0 ]]; then
		print_help
		return 0
	fi

	case "$command" in
		-h|--help)
			if [[ "$argument_count" -ne 0 ]]; then
				error "Usage: ${script_name} <command> [options]"
			fi
			print_help
			return 0
			;;
		help)
			if [[ "$argument_count" -eq 0 ]]; then
				print_help
				return 0
			fi

			if [[ "$argument_count" -eq 1 ]] && is_help_flag "$first_argument"; then
				print_command_help help
				return 0
			fi

			error "Usage: ${script_name} help"
			;;
		start|patch|status|review|commit|reset|promote|complete|block|resume|get|set|unset)
			if [[ "$argument_count" -eq 1 ]] && is_help_flag "$first_argument"; then
				print_command_help "$command"
				return 0
			fi

			case "$command" in
				status)
					run_operational_command strict handle_status "$argument_count" "${@:2}"
					return 0
					;;
				review)
					run_operational_command strict handle_review "$argument_count" "${@:2}"
					return 0
					;;
				commit)
					run_operational_command strict handle_commit "$argument_count" "${@:2}"
					return 0
					;;
				reset)
					run_operational_command strict handle_reset "$argument_count" "${@:2}"
					return 0
					;;
				promote)
					run_operational_command strict handle_promote "$argument_count" "${@:2}"
					return 0
					;;
				complete)
					run_operational_command strict handle_complete "$argument_count" "${@:2}"
					return 0
					;;
				block)
					run_operational_command strict handle_block "$argument_count" "${@:2}"
					return 0
					;;
				resume)
					run_operational_command strict handle_resume "$argument_count" "${@:2}"
					return 0
					;;
				start)
					run_operational_command strict handle_start "$argument_count" "${@:2}"
					return 0
					;;
				patch)
					run_operational_command strict handle_patch "$argument_count" "${@:2}"
					return 0
					;;
				get)
					handle_config_get "$first_argument" "$second_argument"
					return 0
					;;
				set)
					handle_config_set "$first_argument" "$second_argument"
					return 0
					;;
				unset)
					handle_config_unset "$first_argument" "$second_argument"
					return 0
					;;
				*)
					print_unknown_command "$command"
					return 1
					;;
			esac
			return 0
			;;
		__test-route-args)
			if [[ "${FLOW_TEST_MODE:-0}" != '1' ]]; then
				print_unknown_command "$command"
				return 1
			fi
			run_operational_command strict print_test_arguments "$first_argument" "$second_argument"
			return 0
			;;
		__test-invalid-policy)
			if [[ "${FLOW_TEST_MODE:-0}" != '1' ]]; then
				print_unknown_command "$command"
				return 1
			fi
			run_operational_command bogus print_help
			return 0
			;;
		__test-state-get)
			if [[ "${FLOW_TEST_MODE:-0}" != '1' ]]; then
				print_unknown_command "$command"
				return 1
			fi
			local repo_root
			repo_root="$(resolve_repo_root)"
			local workflow_state_file
			workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
			workflow_state_json_helper 'get' "$workflow_state_file"
			return 0
			;;
		__test-state-set)
			if [[ "${FLOW_TEST_MODE:-0}" != '1' ]]; then
				print_unknown_command "$command"
				return 1
			fi
			if [[ -z "$first_argument" || -n "$second_argument" ]]; then
				error "Usage: ${script_name} __test-state-set <json>"
			fi
			local repo_root
			repo_root="$(resolve_repo_root)"
			local workflow_state_file
			workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
			workflow_state_json_helper 'set' "$workflow_state_file" "$first_argument"
			return 0
			;;
		__test-state-clear)
			if [[ "${FLOW_TEST_MODE:-0}" != '1' ]]; then
				print_unknown_command "$command"
				return 1
			fi
			if [[ -n "$first_argument" || -n "$second_argument" ]]; then
				error "Usage: ${script_name} __test-state-clear"
			fi
			local repo_root
			repo_root="$(resolve_repo_root)"
			local workflow_state_file
			workflow_state_file="$(workflow_state_file_for_repo_root "$repo_root")"
			workflow_state_json_helper 'clear' "$workflow_state_file"
			return 0
			;;
		*)
			print_unknown_command "$command"
			return 1
			;;
	esac
}

main "$@"
