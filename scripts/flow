#!/usr/bin/env bash
set -euo pipefail

script_name="$(basename "${0:-${BASH_SOURCE[0]}}")"

error() {
	printf '%s: %s\n' "$script_name" "$1" >&2
	exit 1
}

resolve_repo_root() {
	local repo_root
	if ! repo_root="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null)"; then
		error 'Not inside a Git repository. Run this command from within a repository.'
	fi

	printf '%s' "$repo_root"
}

config_file_for_repo_root() {
	printf '%s/.ai-dev/config.json' "$1"
}

workflow_state_file_for_repo_root() {
	printf '%s/.ai-dev/workflow.json' "$1"
}

blocked_workflows_file_for_repo_root() {
	printf '%s/.ai-dev/blocked-workflows.json' "$1"
}

resolve_repo_root_if_available() {
	local repo_root
	if repo_root="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null)"; then
		printf '%s' "$repo_root"
		return 0
	fi

	return 1
}

expand_home_prefix() {
	local path_value="$1"

	if [[ "$path_value" == '~' ]]; then
		printf '%s' "$HOME"
		return 0
	fi

	if [[ "${path_value:0:2}" == '~/' ]]; then
		printf '%s/%s' "$HOME" "${path_value:2}"
		return 0
	fi

	printf '%s' "$path_value"
}

resolve_output_destination() {
	local repo_root="$1"
	local configured_path="$2"
	local expanded_path
	expanded_path="$(expand_home_prefix "$configured_path")"

	if [[ "$expanded_path" == /* ]]; then
		printf '%s' "$expanded_path"
		return 0
	fi

	printf '%s/%s' "$repo_root" "$expanded_path"
}

write_routed_output() {
	local temporary_output="$1"
	local destination="$2"
	local parent_directory
	parent_directory="$(dirname "$destination")"

	if [[ ! -d "$parent_directory" ]]; then
		printf '%s: Cannot write output to %s: parent directory does not exist: %s\n' "$script_name" "$destination" "$parent_directory" >&2
		printf '%s: Generated output preserved at %s\n' "$script_name" "$temporary_output" >&2
		return 1
	fi

	if cat "$temporary_output" >"$destination"; then
		rm -f "$temporary_output"
		return 0
	fi

	printf '%s: Cannot write output to %s\n' "$script_name" "$destination" >&2
	printf '%s: Generated output preserved at %s\n' "$script_name" "$temporary_output" >&2
	return 1
}

run_operational_command() {
	local config_error_policy="${1:-}"
	local command_function="${2:-}"

	if [[ "$config_error_policy" != 'strict' && "$config_error_policy" != 'ignore' ]]; then
		error "Unknown operational config policy: ${config_error_policy}. Supported policies: strict, ignore."
	fi

	if [[ -z "$command_function" ]]; then
		error 'Operational command function is required.'
	fi

	shift 2

	local repo_root
	if repo_root="$(resolve_repo_root_if_available)"; then
		local config_file
		config_file="$(config_file_for_repo_root "$repo_root")"

		local out_value
		local helper_status=0
		set +e
		if [[ "$config_error_policy" == 'ignore' ]]; then
			out_value="$(config_json_helper 'get' "$config_file" 'out' 2>/dev/null)"
		else
			out_value="$(config_json_helper 'get' "$config_file" 'out')"
		fi
		helper_status=$?
		set -e
		if [[ "$helper_status" -ne 0 ]]; then
			if [[ "$config_error_policy" == 'ignore' ]]; then
				"$command_function" "$@"
				return $?
			fi
			return "$helper_status"
		fi

		if [[ -n "$out_value" ]]; then
			local temporary_output
			temporary_output="$(mktemp "${TMPDIR:-/tmp}/${script_name}.output.XXXXXX")"

			local command_status=0
			set +e
			"$command_function" "$@" >"$temporary_output"
			command_status=$?
			set -e
			if [[ "$command_status" -ne 0 ]]; then
				cat "$temporary_output"
				rm -f "$temporary_output"
				return "$command_status"
			fi

			cat "$temporary_output"

			local destination
			destination="$(resolve_output_destination "$repo_root" "$out_value")"
			if write_routed_output "$temporary_output" "$destination"; then
				printf 'Output written to %s\n' "$destination"
				return 0
			fi

			return 1
		fi
	fi

	"$command_function" "$@"
}

print_test_arguments() {
	local first="${1:-}"
	local second="${2:-}"
	printf 'arg1=%s\n' "$first"
	printf 'arg2=%s\n' "$second"
}

workflow_state_get_field() {
	local key="$1"
	local state_json="$2"

	python3 - "$key" "$state_json" <<'PY'
import json
import sys

key = sys.argv[1]
data = json.loads(sys.argv[2])
value = data.get(key)
if value is None:
	sys.exit(0)
print(value)
PY
}

build_start_state_payload() {
	local issue_number="$1"
	local issue_title="$2"
	local issue_url="$3"
	local main_branch="$4"
	local scratch_branch="$5"

	python3 - "$issue_number" "$issue_title" "$issue_url" "$main_branch" "$scratch_branch" <<'PY'
import json
import sys

issue_number = int(sys.argv[1])
issue_title = sys.argv[2]
issue_url = sys.argv[3]
main_branch = sys.argv[4]
scratch_branch = sys.argv[5]

payload = {
	'activeIssueNumber': issue_number,
	'mainBranch': main_branch,
	'scratchBranch': scratch_branch,
	'checkpoint': 0,
}

if issue_title:
	payload['activeIssueTitle'] = issue_title

if issue_url:
	payload['activeIssueUrl'] = issue_url

print(json.dumps(payload))
PY
}

