resolve_issue_metadata() {
	local issue_number="$1"

	if ! command -v gh >/dev/null 2>&1; then
		return 0
	fi

	local metadata_json
	local metadata_status=0
	set +e
	metadata_json="$(gh issue view "$issue_number" --json title,url 2>/dev/null)"
	metadata_status=$?
	set -e

	if [[ "$metadata_status" -ne 0 || -z "$metadata_json" ]]; then
		return 0
	fi

	local parsed_metadata
	local parse_status=0
	set +e
	parsed_metadata="$(python3 - "$metadata_json" <<'PY'
import json
import sys

try:
	data = json.loads(sys.argv[1])
except json.JSONDecodeError:
	print('')
	print('')
	sys.exit(0)

title = data.get('title')
url = data.get('url')

if not isinstance(title, str):
	title = ''

if not isinstance(url, str):
	url = ''

print(title.strip())
print(url.strip())
PY
)"
	parse_status=$?
	set -e

	if [[ "$parse_status" -ne 0 ]]; then
		return 0
	fi

	printf '%s\n' "$parsed_metadata"
}

resolve_issue_details_with_labels() {
	local issue_number="$1"

	if ! command -v gh >/dev/null 2>&1; then
		error 'GitHub CLI (gh) is required for this command.'
	fi

	local issue_json
	local issue_status=0
	set +e
	issue_json="$(gh issue view "$issue_number" --json title,url,labels 2>&1)"
	issue_status=$?
	set -e

	if [[ "$issue_status" -ne 0 ]]; then
		error "GitHub issue lookup failed for #${issue_number}: ${issue_json}"
	fi

	local parsed_issue
	local parse_status=0
	set +e
	parsed_issue="$(python3 - "$issue_json" <<'PY'
import json
import sys

try:
	data = json.loads(sys.argv[1])
except json.JSONDecodeError:
	print('', file=sys.stderr)
	sys.exit(1)

title = data.get('title')
url = data.get('url')
labels = data.get('labels')

if not isinstance(title, str):
	title = ''

if not isinstance(url, str):
	url = ''

if not isinstance(labels, list):
	labels = []

label_names = []
for item in labels:
	if isinstance(item, dict):
		name = item.get('name')
		if isinstance(name, str):
			name = name.strip()
			if name:
				label_names.append(name)

print(title.strip())
print(url.strip())
print(','.join(label_names))
PY
)"
	parse_status=$?
	set -e

	if [[ "$parse_status" -ne 0 ]]; then
		error "GitHub issue lookup failed for #${issue_number}: invalid JSON response."
	fi

	printf '%s\n' "$parsed_issue"
}

reconcile_github_workflow_label() {
	local issue_number="$1"
	local target_label="$2"
	local labels_csv="$3"
	local errexit_was_enabled='no'
	if [[ "$-" == *e* ]]; then
		errexit_was_enabled='yes'
	fi

	local reconcile_result
	local reconcile_status=0
	set +e
	reconcile_result="$(python3 - "$target_label" "$labels_csv" <<'PY'
import sys

target = sys.argv[1]
raw_labels = sys.argv[2]
workflow_labels = ['active', 'blocked', 'backlog']

labels = []
for entry in raw_labels.split(','):
	entry = entry.strip()
	if entry:
		labels.append(entry)

remove = []
for label in workflow_labels:
	if label != target and label in labels:
		remove.append(label)

add_needed = 'yes' if target not in labels else 'no'
print(','.join(remove))
print(add_needed)
PY
)"
	reconcile_status=$?
	if [[ "$errexit_was_enabled" == 'yes' ]]; then
		set -e
	fi

	if [[ "$reconcile_status" -ne 0 ]]; then
		printf '%s: GitHub label reconciliation failed for #%s.\n' "$script_name" "$issue_number" >&2
		return 1
	fi

	local reconcile_lines=()
	mapfile -t reconcile_lines <<< "$reconcile_result"
	local labels_to_remove="${reconcile_lines[0]:-}"
	local add_needed="${reconcile_lines[1]:-no}"

	local edit_args=(issue edit "$issue_number")
	if [[ "$add_needed" == 'yes' ]]; then
		edit_args+=(--add-label "$target_label")
	fi
	if [[ -n "$labels_to_remove" ]]; then
		edit_args+=(--remove-label "$labels_to_remove")
	fi

	if [[ "$add_needed" != 'yes' && -z "$labels_to_remove" ]]; then
		return 0
	fi

	local edit_output
	local edit_status=0
	set +e
	edit_output="$(gh "${edit_args[@]}" 2>&1)"
	edit_status=$?
	if [[ "$errexit_was_enabled" == 'yes' ]]; then
		set -e
	fi

	if [[ "$edit_status" -ne 0 ]]; then
		printf '%s: GitHub label reconciliation failed for #%s: %s\n' "$script_name" "$issue_number" "$edit_output" >&2
		return 1
	fi
}

build_patch_state_payload() {
	local description="$1"
	local main_branch="$2"
	local scratch_branch="$3"
	local checkpoint="$4"

	python3 - "$description" "$main_branch" "$scratch_branch" "$checkpoint" <<'PY'
import json
import sys

description = sys.argv[1]
main_branch = sys.argv[2]
scratch_branch = sys.argv[3]
checkpoint = int(sys.argv[4])

payload = {
	'patchDescription': description,
	'mainBranch': main_branch,
	'scratchBranch': scratch_branch,
	'checkpoint': checkpoint,
}

print(json.dumps(payload))
PY
}

workflow_kind_from_state() {
	local active_issue_number="$1"
	local patch_description="$2"

	if [[ -n "$active_issue_number" ]]; then
		printf 'issue'
		return 0
	fi

	if [[ -n "$patch_description" ]]; then
		printf 'patch'
		return 0
	fi

	printf 'inactive'
}

count_numbered_scratch_checkpoints() {
	local repo_root="$1"
	local main_branch="$2"
	local scratch_branch="$3"

	local max_checkpoint=0
	local subject
	while IFS= read -r subject; do
		if [[ "$subject" =~ ^[1-9][0-9]*$ ]]; then
			if (( subject > max_checkpoint )); then
				max_checkpoint=$subject
			fi
		fi
	done < <(git -C "$repo_root" log --format=%s "${main_branch}..${scratch_branch}")

	printf '%s' "$max_checkpoint"
}

