{
  "name": "ai-dev-vscode",
  "displayName": "ai-dev-vscode",
  "description": "Thin VS Code wrapper for AI Dev workflows",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.123.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiDev",
          "title": "AI Dev",
          "icon": "resources/ai-dev.svg"
        }
      ]
    },
    "submenus": [
      {
        "id": "aiDev.menu",
        "label": "AI Dev"
      }
    ],
    "views": {
      "aiDev": [
        {
          "id": "aiDev.launcher",
          "name": "Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "aiDev.launchAssistant",
        "title": "Launch Assistant",
        "category": "AI Dev"
      },
      {
        "command": "aiDev.generateUnitDocPromptForActiveFile",
        "title": "Generate Summary Doc for Selected File",
        "category": "AI Dev"
      },
      {
        "command": "aiDev.generateUnitDocsBatchExperimental",
        "title": "Batch Summary Doc Generation",
        "category": "AI Dev"
      },
      {
        "command": "aiDev.generateArchitectureSummary",
        "title": "Generate Architecture Summary",
        "category": "AI Dev"
      },
      {
        "command": "aiDev.updateFolderSummary",
        "title": "Batch Summary Doc Generation",
        "category": "AI Dev"
      },
      {
        "command": "aiDev.reviewChangedDocsPrompt",
        "title": "Review Summary Docs",
        "category": "AI Dev",
        "icon": "$(checklist)"
      },
      {
        "command": "aiDev.reviewFileDocsPrompt",
        "title": "Review Summary Doc for Selected File",
        "category": "AI Dev",
        "icon": "$(checklist)"
      },
      {
        "command": "aiDev.answerFromAiDocsPrompt",
        "title": "Answer From Summary Docs",
        "category": "AI Dev",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "aiDev.copilotTest",
        "title": "Copilot Test",
        "category": "AI Dev"
      },
      {
        "command": "aiDev.settings",
        "title": "Settings",
        "category": "AI Dev"
      }
    ],
    "menus": {
      "aiDev.menu": [
        {
          "command": "aiDev.generateUnitDocPromptForActiveFile",
          "group": "1_generateUnitDoc"
        },
        {
          "command": "aiDev.updateFolderSummary",
          "group": "1b_updateFolderSummary"
        },
        {
          "command": "aiDev.generateArchitectureSummary",
          "group": "1c_generateArchitectureSummary"
        },
        {
          "command": "aiDev.reviewChangedDocsPrompt",
          "group": "2_reviewChangedDocs"
        },
        {
          "command": "aiDev.reviewFileDocsPrompt",
          "group": "3_reviewFileDocs"
        },
        {
          "command": "aiDev.answerFromAiDocsPrompt",
          "group": "4_answerFromDocs"
        }
      ],
      "explorer/context": [
        {
          "submenu": "aiDev.menu",
          "when": "resourceScheme == file && !explorerResourceReadonly",
          "group": "navigation@50"
        }
      ],
      "editor/context": [
        {
          "submenu": "aiDev.menu",
          "when": "resourceScheme == file",
          "group": "navigation@50"
        }
      ],
      "scm/title": [
        {
          "submenu": "aiDev.menu",
          "group": "navigation@50"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "npx --yes @vscode/vsce package --out ../artifacts/ai-dev-vscode-${npm_package_version}.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.123.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.6.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "publisher": "jmrozi1",
  "activationEvents": [
    "onCommand:aiDev.launchAssistant",
    "onCommand:aiDev.generateUnitDocPromptForActiveFile",
    "onCommand:aiDev.generateUnitDocsBatchExperimental",
    "onCommand:aiDev.generateArchitectureSummary",
    "onCommand:aiDev.updateFolderSummary",
    "onCommand:aiDev.reviewChangedDocsPrompt",
    "onCommand:aiDev.reviewFileDocsPrompt",
    "onCommand:aiDev.answerFromAiDocsPrompt",
    "onCommand:aiDev.copilotTest",
    "onCommand:aiDev.settings"
  ],
  "files": [
    "out/**",
    "resources/**",
    "vendor/ai-dev-core/**",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jmrozi1/ai-dev.git"
  },
  "allowScripts": {
    "@vscode/vsce-sign@2.0.9": true,
    "keytar@7.9.0": true
  }
}
