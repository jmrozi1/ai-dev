{
  "name": "ai-dev-vscode",
  "displayName": "ai-dev-vscode",
  "description": "Thin VS Code wrapper for AI Dev workflows",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.123.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiDev",
          "title": "AI Dev",
          "icon": "resources/ai-dev.svg"
        }
      ]
    },
    "views": {
      "aiDev": [
        {
          "id": "aiDev.launcher",
          "name": "Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "aiDev.launchAssistant",
        "title": "Launch Assistant",
        "category": "AI Dev"
      },
      {
        "command": "aiDev.settings",
        "title": "Settings",
        "category": "AI Dev"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "npx --yes @vscode/vsce package --out ../artifacts/ai-dev-vscode-${npm_package_version}.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.123.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.6.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "publisher": "jmrozi1",
  "activationEvents": [
    "onCommand:aiDev.launchAssistant",
    "onCommand:aiDev.settings"
  ],
  "files": [
    "out/**",
    "resources/**",
    "vendor/ai-dev-core/**",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jmrozi1/ai-dev.git"
  },
  "allowScripts": {
    "@vscode/vsce-sign@2.0.9": true,
    "keytar@7.9.0": true
  }
}
